{
  "compilerOptions": {
    "module": "es2015",
    "moduleResolution": "Node",
    "target": "es2020",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "{root}/*": [
        "*"
      ],
      "{src}/*": [
        "src/*"
      ],
      "{types}/*": [
        "src/types/*"
      ],
      "{core}/*": [
        "src/core/*"
      ],
      "{modules}/*": [
        "src/modules/*"
      ],
      "{test}/*": [
        "src/test/*"
      ],
      "{app}/*": [
        "src/app/*"
      ],
      "{dist}/*": [
        "dist/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/types/global.d.ts"
  ]
}